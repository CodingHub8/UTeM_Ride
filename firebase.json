{
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", ".env"]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "hosting",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      {
        "source": "/payment/callback",
        "destination": "/payment-success.html"
      }
    ]
  }
}
